# ============================================================
# Digital Egypt Pioneers AI Mentor - Environment Configuration
# ============================================================

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Model Settings
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/depi_mentor

# ChromaDB Settings
CHROMA_PERSIST_DIR=./data/chroma_db

# RAG Settings
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit Settings
STREAMLIT_PORT=8501
